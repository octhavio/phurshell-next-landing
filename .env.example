# WordPress API Configuration
# Quando integrar o WordPress headless, configurar estas variáveis
WORDPRESS_API_URL=https://seu-wordpress.com/wp-json/wp/v2
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Revalidation (ISR)
REVALIDATE_SECRET=seu-secret-aqui

# SEO & Analytics
# Google Search Console - Obtenha em: https://search.google.com/search-console
# Exemplo: NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=abc123xyz456
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools - Obtenha em: https://www.bing.com/webmasters
# Exemplo: NEXT_PUBLIC_BING_SITE_VERIFICATION=123ABC456DEF
NEXT_PUBLIC_BING_SITE_VERIFICATION=
